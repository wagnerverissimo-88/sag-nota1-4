# Adicionar aqui variáveis de ambiente da Vercel se necessário
# Exemplo: VITE_API_URL="sua_api_aqui"

# API Key da RAWG para busca de jogos com autocomplete
# Cadastro gratuito em: https://rawg.io/apimgmt
# Sem essa variável, o campo de nome do jogo funciona como input de texto simples.
VITE_RAWG_API_KEY="sua_chave_rawg_aqui"